---
import Layout from "../layouts/Layout.astro";
import TarotDraw from "../components/react/TarotDraw.tsx";
import VoiceSection from "../components/VoiceSection.astro";
import { getNews } from "../library/microcms";
import { format } from "date-fns";

const response = await getNews({
	limit: 3,
	fields: ["id", "title", "publishedAt", "category", "eyecatch"],
});
const { contents: newsList } = response;

function formatDate(dateString: string) {
	return format(new Date(dateString), "yyyy.MM.dd");
}
// const newsList: any[] = [];

import { getCourses } from "../library/microcms";

const coursesResponse = await getCourses();
const courseCategories = coursesResponse.contents.map(course => ({
    id: course.slug, // Use slug for ID to match existing logic (or course.id if preferred, but existing used IDs like 'tarot')
    name: course.title,
    description: course.subTitle || "",
    steps: course.steps.map(step => ({ step: step.stepNumber, label: step.label })),
    cards: course.cards.map(card => {
        let url = card.url;
        let img = card.image?.url || "/images/placeholder.jpg";

        if (card.title.includes("リーダー")) {
            url = "/course#reader";
            img = "/images/home/leader_1.webp";
        } else if (card.title.includes("コーチ")) {
            url = "/course#coach";
            img = "/images/home/coach_1.webp";
        } else if (card.title.includes("ティーチャー")) {
            url = "/course#teacher";
             img = "/images/home/teacher_1.webp";
        }

        return {
            title: card.title,
            img: img,
            url: url
        };
    })
}));
---

<Layout title="Home" wide={true} isHome={true}>
	<!-- Hero Section (Immersive Full Screen) -->
	<section
		class="relative h-screen w-full flex items-center justify-center overflow-hidden"
	>
		<!-- Background Image Slideshow -->
		<div class="absolute inset-0 z-0">
			<div
				class="absolute inset-0 bg-text-dark/30 z-10 pointer-events-none"
			>
			</div>
			<!-- Overlay -->

			<img
				src="/images/home/top_1.webp"
				alt="Hero Background 1"
				class="absolute inset-0 w-full h-full object-cover transition-opacity duration-[2000ms] ease-in-out opacity-100 hero-bg"
				data-index="0"
                loading="eager"
                decoding="sync"
			/>
			<img
				src="/images/home/top_2.webp"
				alt="Hero Background 2"
				class="absolute inset-0 w-full h-full object-cover transition-opacity duration-[2000ms] ease-in-out opacity-0 hero-bg"
				data-index="1"
                loading="eager"
                decoding="sync"
			/>
			<img
				src="/images/home/top_3.webp"
				alt="Hero Background 3"
				class="absolute inset-0 w-full h-full object-cover transition-opacity duration-[2000ms] ease-in-out opacity-0 hero-bg"
				data-index="2"
                loading="eager"
                decoding="sync"
			/>
		</div>

		<script>
			// Crossfade for hero images (3 images)
            const heroBgs = document.querySelectorAll('.hero-bg');
            let currentIndex = 0;

            if (heroBgs.length > 0) {
                setInterval(() => {
                    const nextIndex = (currentIndex + 1) % heroBgs.length;
                    
                    heroBgs[currentIndex].classList.remove('opacity-100');
                    heroBgs[currentIndex].classList.add('opacity-0');
                    
                    heroBgs[nextIndex].classList.remove('opacity-0');
                    heroBgs[nextIndex].classList.add('opacity-100');

                    currentIndex = nextIndex;
                }, 5000);
            }
		</script>

		<!-- Hero Content -->
		<div class="relative z-20 text-center text-white px-10">
			<h1
				class="text-4xl md:text-8xl font-bold mb-6 tracking-wide drop-shadow-lg leading-tight animate-fade-in-up delay-100"
			>
				Voyager Tarot<br />
				<span>Creations</span>
			</h1>

			<p
				class="text-base md:text-2xl tracking-widest opacity-90 mb-8 md:mb-12 animate-fade-in-up delay-200"
			>
				未来を創造する力を、あなたに。
			</p>

			<div
				class="flex flex-col sm:flex-row justify-center gap-6 animate-fade-in-up delay-300"
			>
				<a
					href="#tarot-draw"
					class="bg-gradient-to-r from-[#ff80ab] to-[#ffb300] text-white px-10 py-4 rounded-full hover:scale-105 transition-all duration-300 font-bold tracking-wide shadow-lg shadow-pink-200"
				>
					今日の1枚を引く
				</a>
                <a
                    href="#course"
                    class="bg-white/10 backdrop-blur-md border border-white/50 text-white px-10 py-4 rounded-full hover:bg-white hover:text-text-dark transition-all duration-300 font-bold tracking-wide shadow-lg"
                >
                    講座一覧を見る
                </a>
			</div>
		</div>
	</section>

	<!-- Content Wrapper -->
	<div class="bg-gradient-to-br from-pink-50 via-white to-yellow-50 relative z-10">

		<!-- 1-4. CONSOLIDATED SECTION: WHO WE ARE (Brand Story) -->
		<section class="mb-16 md:mb-32 pt-12 md:pt-24 px-6 relative">
			<div class="max-w-7xl mx-auto">
                <div class="scroll-animation opacity-0">

                    <div class="space-y-16 md:space-y-32"> <!-- Unified vertical spacing for flow -->
                        
                        <!-- BLOCK 1: WHAT IS VOYAGER TAROT -->
                        <div class="py-8 md:py-12 relative overflow-hidden group border-t border-b border-magenta/20 my-8">
                             <div class="absolute -top-10 -right-10 w-32 h-32 bg-magenta/20 rounded-full blur-3xl opacity-50"></div>
                            <div class="flex flex-col md:flex-row items-center gap-8 md:gap-16 relative z-10">
                                 <!-- Image Side -->
                                <div class="w-full md:w-1/2 rounded-[2rem] overflow-hidden shadow-2xl transform group-hover:scale-105 transition-transform duration-500 shadow-magenta/10 aspect-[3/2]">
                                     <img
                                        src="/images/home/home_1.webp"
                                        alt="Voyager Tarot Card"
                                        class="w-full h-full object-cover"
                                        loading="lazy"
                                        decoding="async"
                                    />
                                </div>
                                 <!-- Text Side -->
                                <div class="w-full md:w-1/2">
                                    <div class="mb-10 relative">
                                        <div class="inline-block bg-magenta text-white px-8 py-4 rounded-xl shadow-lg relative z-10">
                                            <h3 class="text-2xl font-bold font-mincho tracking-wider">
                                                ボイジャータロットとは？
                                            </h3>
                                        </div>
                                        <div class="absolute -bottom-2 -left-2 w-full h-full bg-magenta/10 rounded-xl -z-10"></div>
                                    </div>
                                    <h4 class="text-xl md:text-2xl font-bold text-text-dark mb-6 leading-tight">
                                        『生きたい人生を<br/>創造するためのツール』
                                    </h4>

                                    <div class="space-y-4 md:space-y-6 text-lg text-gray-500 leading-relaxed">
                                        <p class="flex gap-2">
                                            <span class="text-magenta mt-1 shrink-0">●</span>
                                            <span>
                                                ボイジャータロットは従来のタロットとは少し違います。<br/>
                                                タロット＝占いではなく、より深く自分を知り、成長させてくれるアイテムです。
                                            </span>
                                        </p>
                                        <p class="flex gap-2">
                                            <span class="text-magenta mt-1 shrink-0">●</span>
                                            <span>
                                                78枚のカードには神話の神々や、人物、遺跡、自然、宇宙、植物、動物など、たくさんの象徴が美しいコラージュとして描かれ、眺めているだけで様々なインスピレーションや感情が湧いてきます。
                                            </span>
                                        </p>
                                        <p class="flex gap-2">
                                            <span class="text-magenta mt-1 shrink-0">●</span>
                                            <span>
                                                なんと言ってもボイジャータロットの素晴らしさは、本来持っている才能を引き出すパワーにあります。さらに、発見した才能を開花させる道をも示し、願望実現へと導く行動を促すエネルギーを与えてくれる、スピリチュアルでありながら現実的なタロットカードです。
                                            </span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- BLOCK 2: ABOUT CREATIONS -->
                        <div class="py-8 md:py-12 relative overflow-hidden group border-t border-b border-sunshine/20 my-8">
                             <div class="absolute -top-10 -left-10 w-32 h-32 bg-sunshine/20 rounded-full blur-3xl opacity-50"></div>
                            <div class="flex flex-col md:flex-row items-center gap-8 md:gap-16 relative z-10">
                                <!-- Text Side -->
                                <div class="w-full md:w-1/2 order-2 md:order-1">
                                    <div class="mb-10 relative">
                                        <div class="inline-block bg-sunshine text-white px-8 py-4 rounded-xl shadow-lg relative z-10">
                                            <h3 class="text-2xl font-bold font-mincho tracking-wider leading-tight">
                                                ボイジャータロット<br/>クリエイションズについて
                                            </h3>
                                        </div>
                                        <div class="absolute -bottom-2 -right-2 w-full h-full bg-sunshine/10 rounded-xl -z-10"></div>
                                    </div>
                                    <div class="space-y-6 text-lg text-gray-500 leading-relaxed">
                                         <p class="text-xl md:text-2xl font-bold text-text-dark leading-relaxed">
                                            認定ティーチャーとして<br/>10年以上の経験を持つ<br/>
                                            <span class="text-sunshine border-b-2 border-sunshine/30">青木咲羅</span>が主宰する団体です。
                                        </p>
                                        <p>
                                            ボイジャータロットの作者、ジェームズ・ワンレス博士の源流を正統に受け継ぎながら、他の占術や心理セラピストとしての知識も合わせた、より広く、深いアプローチを探求しています。
                                        </p>
                                        <p>
                                            みんなが「生きたい人生を創造する」ためのツールとして、魅力的で実力あるリーダー、コーチ、ティーチャーの育成を目指して活動しています。
                                        </p>
                                    </div>
    
                                    <div class="mt-8">
                                        <a
                                            href="/profile"
                                            class="inline-flex items-center gap-2 px-8 py-3 rounded-full bg-sunshine text-white font-bold tracking-widest hover:bg-sunshine/90 hover:scale-105 transition-all shadow-lg text-sm"
                                        >
                                            PROFILE &rarr;
                                        </a>
                                    </div>
                                </div>
                                 <!-- Image Side -->
                                 <div class="w-full md:w-1/2 order-1 md:order-2 rounded-[2rem] overflow-hidden shadow-2xl transform group-hover:scale-105 transition-transform duration-500 shadow-sunshine/10 aspect-[3/2]">
                                       <img
                                           src="/images/home/home_2.webp"
                                           alt="Voyager Tarot Session"
                                           class="w-full h-full object-cover"
                                           loading="lazy"
                                           decoding="async"
                                       />
                                </div>
                            </div>
                        </div>

                        <!-- BLOCK 3: CAREER PATH (NEW) -->
                        <div class="py-16 md:py-24 bg-blue-50/50 rounded-[3rem] px-6 md:px-16 mx-[-1rem] md:mx-0">
                            <div class="text-center mb-20 md:mb-28">
                                <div class="relative inline-block mx-4">
                                    <h3 class="relative z-20 bg-sky text-white text-2xl md:text-4xl font-bold px-16 py-6 shadow-xl tracking-wider">
                                        プロフェッショナルへの道
                                    </h3>
                                    <!-- Left Tail -->
                                    <div class="absolute top-3 -left-5 h-full w-full bg-sky -z-10 rounded-l-lg"></div>
                                    <!-- Right Tail -->
                                    <div class="absolute top-3 -right-5 h-full w-full bg-sky -z-10 rounded-r-lg"></div>
                                    
                                    <!-- Left Fold (Darker Triangle) -->
                                    <div class="absolute top-full left-0 w-0 h-0 border-t-[12px] border-t-[#0288d1] border-l-[12px] border-l-transparent z-10"></div>
                                    <!-- Right Fold (Darker Triangle) -->
                                    <div class="absolute top-full right-0 w-0 h-0 border-t-[12px] border-t-[#0288d1] border-r-[12px] border-r-transparent z-10"></div>
                                </div>
                            </div>

                            <div class="grid md:grid-cols-2 gap-8">
                                <!-- Card 1: 3 Months -->
                                <div class="bg-white/40 backdrop-blur-sm rounded-[2rem] p-8 md:p-10 relative overflow-hidden group hover:-translate-y-2 transition-transform duration-300 border-t-4 border-sky shadow-sm">
                                    <div class="absolute top-0 right-0 p-4 opacity-10">
                                        <span class="text-8xl font-bold text-sky">3</span>
                                    </div>
                                    <div class="bg-sky text-white px-5 py-2 rounded-full text-sm font-bold inline-block mb-6 shadow-sm">STEP 1</div>
                                    <h4 class="text-2xl md:text-4xl font-bold text-text-dark mb-6 relative z-10 leading-snug">
                                        <span class="text-sky underline decoration-sky/30 underline-offset-8">3ヶ月</span>で<br/>プロのタロットリーダーに！
                                    </h4>
                                    <p class="text-gray-500 leading-relaxed mb-6 font-medium relative z-10 text-lg">
                                        ボイジャータロットリーダー認定講座（ベーシック・アドバンス）を受講し、課題と認定テスト合格で、プロのタロットリーダーとして認定を受けられます。
                                    </p>
                                    <p class="text-sm text-gray-400 bg-white/50 backdrop-blur-sm p-6 rounded-2xl relative z-10 leading-relaxed italic">
                                        毎月の無料練習会や勉強会、LINEでの質問メールなど、受講後のアフターフォローも充実しているので、安心して学ぶことが出来ます。
                                    </p>
                                </div>

                                <!-- Card 2: 1 Year -->
                                <div class="bg-white/40 backdrop-blur-sm rounded-[2rem] p-8 md:p-10 relative overflow-hidden group hover:-translate-y-2 transition-transform duration-300 border-t-4 border-sky shadow-sm">
                                     <div class="absolute top-0 right-0 p-4 opacity-10">
                                        <span class="text-8xl font-bold text-sky">1</span>
                                    </div>
                                    <div class="bg-sky text-white px-5 py-2 rounded-full text-sm font-bold inline-block mb-6 shadow-sm">STEP 2</div>
                                    <h4 class="text-2xl md:text-4xl font-bold text-text-dark mb-6 relative z-10 leading-snug">
                                        <span class="text-sky underline decoration-sky/30 underline-offset-8">1年</span>で<br/>ティーチャーを目指す！
                                    </h4>
                                    <p class="text-gray-500 leading-relaxed mb-6 font-medium relative z-10 text-lg">
                                        リーダー・コーチ・ティーチャーの認定講座を受講し、規定の課題、認定テスト合格で、ボイジャータロット講座を開講出来る、ティーチャーになる事が出来ます。
                                    </p>
                                    <p class="text-sm text-gray-400 bg-white/50 backdrop-blur-sm p-6 rounded-2xl relative z-10 leading-relaxed italic">
                                        リーダー認定同様、受講後のアフターフォローや講師のアシスタントとして講座に参加する事で経験を積むことが出来ます。独立開業や集客についての学びも出来るので、万全の体制でティーチャーデビューする事が出来ます。
                                    </p>
                                </div>
                            </div>
                        </div>


                        <!-- BLOCK 4: MISSION (Text Left, Image Right) -->
                                <div class="py-8 md:py-12 relative overflow-hidden group border-t border-b border-mint/20 my-8">
                                    <div class="absolute top-1/2 left-0 w-64 h-64 bg-mint/30 rounded-full blur-3xl -translate-y-1/2 -z-10 opacity-70"></div>
                                    <div class="flex flex-col md:flex-row items-center gap-8 md:gap-16 relative z-10">
                                         <!-- Text Side -->
                                        <div class="w-full md:w-1/2 text-left order-2 md:order-1">
                                            <div class="relative inline-block mb-10">
                                                <h3 class="text-2xl md:text-3xl font-bold text-text-dark leading-tight relative z-10 font-mincho">
                                                    未来を創造する力を、<br/><span class="text-mint">あなたに。</span>
                                                </h3>
                                                <div class="absolute -bottom-2 left-0 w-full h-0.5 bg-mint/30"></div>
                                            </div>
                                            
                                            <div class="space-y-6 text-lg text-gray-500 leading-relaxed relative z-10">
                                                <p>
                                                    ボイジャータロットを通じて、<br/>皆さまの成長と可能性を広げること。
                                                </p>
                                                <p>
                                                    創造性・成長・実現化をテーマに、魅力的、かつ実力あるボイジャータロットリーダー、コーチ、ティーチャーの育成に取り組んでまいります。
                                                </p>
                                            </div>
                                        </div>
            
                                        <!-- Image Side -->
                                         <div class="w-full md:w-1/2 order-1 md:order-2 rounded-[2rem] overflow-hidden shadow-2xl transform group-hover:-translate-y-2 transition-transform duration-500 shadow-mint/20 aspect-[3/2]">
                                             <img
                                                src="/images/home/home_3.webp"
                                                alt="Mission Photo"
                                                class="w-full h-full object-cover"
                                                loading="lazy"
                                                decoding="async"
                                            />
                                        </div>
                                    </div>
                                </div>

                    </div>
                </div>
            </div>
		</section>

		<!-- 5. COURSE (Scalable Sidebar Layout) -->
		<section id="course" class="mb-16 md:mb-32 px-6 py-12 md:py-24 relative scroll-mt-32 bg-gray-50 rounded-[2rem] md:rounded-[3rem]">
			<div class="max-w-7xl mx-auto">
            <div class="scroll-animation opacity-0">
                 <div class="mb-16 md:mb-24 text-center">
                    <div class="relative inline-block mt-8">
                        {/* Hanging String (Triangle) */}
                        <div class="absolute -top-8 left-1/2 -translate-x-1/2 w-0 h-0 border-l-[60px] border-l-transparent border-r-[60px] border-r-transparent border-b-[32px] border-b-magenta z-0"></div>
                        <div class="absolute -top-[30px] left-1/2 -translate-x-1/2 w-0 h-0 border-l-[58px] border-l-transparent border-r-[58px] border-r-transparent border-b-[30px] border-b-white z-10"></div>
                        
                        {/* Main Board - Reverted to Decorative Box with solid fill preference */}
                        <div class="bg-magenta text-white border-4 border-magenta px-16 py-6 shadow-2xl relative z-20 min-w-[300px] md:min-w-[450px]">
                             {/* Top Bar Decoration */}
                             <div class="absolute -top-2 left-[-4px] right-[-4px] h-3 bg-white/20 rounded-full border border-white/30"></div>
                            
                            <h2 class="text-3xl md:text-4xl font-bold tracking-widest font-mincho">
                                講座紹介
                            </h2>
 
                             {/* Bottom Bar Decoration */}
                             <div class="absolute -bottom-2 left-[-4px] right-[-4px] h-3 bg-white/20 rounded-full border border-white/30"></div>
                             
                             {/* Pull Tab Decoration */}
                             <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-3 h-3 rounded-full border-2 border-magenta bg-white"></div>
                             <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-[2px] h-2 bg-magenta"></div>
                        </div>
                        <div class="absolute inset-0 bg-magenta/10 blur-2xl -z-10 transform translate-y-4 scale-95"></div>
                    </div>
                </div>

                <div class="grid md:grid-cols-12 gap-12">
                    <!-- Left Sidebar (Title & Tabs) -->
                    <div class="md:col-span-3">
                        <div class="">                            
                            <!-- Vertical Tabs -->
                            <div class="flex flex-col gap-4">
                                {courseCategories.map((cat, index) => (
                                    <button
                                        class:list={[
                                            "course-tab text-left px-6 py-4 rounded-xl transition-all duration-300 font-bold tracking-wide flex items-center justify-between group",
                                            index === 0 
                                                ? "bg-text-dark text-white shadow-xl shadow-blue-200" 
                                                : "bg-white text-gray-500 hover:text-text-dark hover:bg-blue-50"
                                        ]}
                                        data-target={`course-content-${cat.id}`}
                                    >
                                        <span class="z-10 relative">{cat.name}</span>
                                        <span class:list={["w-2 h-2 rounded-full transition-all", index === 0 ? "bg-sakura-vivid" : "bg-gray-300 group-hover:bg-text-dark"]}></span>
                                    </button>
                                ))}
                            </div>
                        </div>
                    </div>

                    <div class="md:col-span-9">
                    {courseCategories.map((cat, index) => (
                        <div 
                            id={`course-content-${cat.id}`} 
                            class:list={["course-content transition-all duration-500", index !== 0 ? "hidden" : ""]}
                        >
                            <!-- Steps Visualization -->
                            <div class="mb-20">
                                <h3 class="text-center font-bold text-gray-400 text-sm tracking-widest mb-10 opacity-70">- STEP UP FLOW -</h3>
                                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-text-dark font-bold">
                                    {cat.steps.map((step, i) => {
                                        const stepColors = ["bg-sakura-vivid", "bg-sunshine", "bg-sky"];
                                        const colorClass = stepColors[i % stepColors.length];
                                        return (
                                        <div class="relative flex flex-col items-center justify-center group/step">
                                            <div class="bg-white px-6 py-4 md:p-8 rounded-2xl border-[3px] border-blue-50 shadow-md flex items-center justify-start md:justify-center gap-4 w-full max-w-[280px] md:max-w-none relative z-10 hover:shadow-lg hover:border-blue-200 transition-all duration-300">
                                                <span class={`w-8 h-8 ${colorClass} text-white rounded-full flex items-center justify-center text-sm font-sans shadow-sm shrink-0`}>
                                                    {step.step}
                                                </span>
                                                <span class="whitespace-nowrap text-lg">{step.label}</span>
                                            </div>
                                            
                                            {i < cat.steps.length - 1 && (
                                                <div class="absolute z-20 text-gray-300
                                                    md:top-1/2 md:left-full md:ml-3 md:-translate-x-1/2 md:-translate-y-1/2 md:bottom-auto md:right-auto md:mt-0
                                                    top-full left-1/2 mt-3 -translate-x-1/2 -translate-y-1/2
                                                ">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="rotate-90 md:rotate-0">
                                                        <path d="m9 18 6-6-6-6"></path>
                                                    </svg>
                                                </div>
                                            )}
                                        </div>
                                    )})}
                                </div>
                            </div>
                            <!-- Course Cards Grid -->
                            <div class="grid md:grid-cols-3 gap-8">
                                {cat.cards.map((card) => (
                                    <a href={card.url} class="group block h-full">
                                        <div class="overflow-hidden rounded-3xl mb-5 shadow-lg shadow-gray-100 relative aspect-[4/3] border-[3px] border-transparent group-hover:border-sakura-vivid/50 transition-all duration-300">
                                            <div class="absolute inset-0 bg-text-dark/0 group-hover:bg-text-dark/10 transition-colors z-10"></div>
                                            <img
                                                src={card.img}
                                                alt={card.title}
                                                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                                loading="lazy"
                                                decoding="async"
                                            />
                                        </div>
                                        <h3 class="font-bold text-center text-lg text-text-dark group-hover:text-sakura-vivid transition-colors mb-2">
                                            {card.title}

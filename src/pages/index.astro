<script>
            // Tab Switching Logic
            const tabs = document.querySelectorAll('.course-tab');
            const contents = document.querySelectorAll('.course-content');

            tabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    const targetId = (tab as HTMLElement).dataset.target;
                    if (!targetId) return;

                    // 1. Reset Tabs
                    tabs.forEach(t => {
                        t.classList.remove('bg-text-dark', 'text-white', 'shadow-xl', 'shadow-blue-200');
                        t.classList.add('bg-white', 'text-gray-500');
                         // reset marker
                         const marker = t.querySelector('span:last-child');
                         if(marker) {
                             marker.classList.remove('bg-sakura-vivid');
                             marker.classList.add('bg-gray-300');
                         }
                    });

                    // 2. Active Tab
                    tab.classList.remove('bg-white', 'text-gray-500');
                    tab.classList.add('bg-text-dark', 'text-white', 'shadow-xl', 'shadow-blue-200');
                     const activeMarker = tab.querySelector('span:last-child');
                         if(activeMarker) {
                             activeMarker.classList.remove('bg-gray-300');
                             activeMarker.classList.add('bg-sakura-vivid');
                         }

                    // 3. Switch Content
                    contents.forEach(content => {
                        content.classList.add('hidden');
                        content.classList.remove('animate-fade-in-up');
                    });
                    
                    const targetContent = document.getElementById(targetId);
                    if (targetContent) {
                        targetContent.classList.remove('hidden');
                         targetContent.classList.add('animate-fade-in-up');
                    }
                });
            });

            // Scroll Reveal Animation (Draw Card Effect)
            const observerOptions = {
                root: null,
                rootMargin: '0px 0px 100px 0px',
                threshold: 0.05
            };

            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.remove('opacity-0');
                        entry.target.classList.add('animate-draw-card');
                        observer.unobserve(entry.target); // Draw once per session
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.scroll-animation').forEach(el => {
                observer.observe(el);
            });
        </script>



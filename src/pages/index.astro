---
import Layout from "../layouts/Layout.astro";
import TarotDraw from "../components/react/TarotDraw.tsx";
import VoiceSection from "../components/VoiceSection.astro";
import { getNews } from "../library/microcms";
import { format } from "date-fns";
import { Image } from "astro:assets";

import top1Img from "../assets/images/home/top_1.webp";
import top2Img from "../assets/images/home/top_2.webp";
import top3Img from "../assets/images/home/top_3.webp";
import home1Img from "../assets/images/home/home_1.webp";
import home2Img from "../assets/images/home/home_2.webp";
import home3Img from "../assets/images/home/home_3.webp";
import leader1Img from "../assets/images/home/leader_1.webp";
import coach1Img from "../assets/images/home/coach_1.webp";
import teacher1Img from "../assets/images/home/teacher_1.webp";
import placeholderImg from "../assets/images/placeholder.jpg";

const response = await getNews({
	limit: 3,
	fields: ["id", "title", "publishedAt", "category", "eyecatch"],
});
const { contents: newsList } = response;

import Video from 'lucide-astro/Video';
import GraduationCap from 'lucide-astro/GraduationCap';
import MessageCircle from 'lucide-astro/MessageCircle';
import Users from 'lucide-astro/Users';
import UserPlus from 'lucide-astro/UserPlus';
import Presentation from 'lucide-astro/Presentation';
import Briefcase from 'lucide-astro/Briefcase';
import PlusCircle from 'lucide-astro/PlusCircle';
function formatDate(dateString: string) {
	return format(new Date(dateString), "yyyy.MM.dd");
}
// const newsList: any[] = [];

import { getCourses } from "../library/microcms";

const coursesResponse = await getCourses();
const courseCategories = coursesResponse.contents.map(course => ({
    id: course.slug, // Use slug for ID to match existing logic (or course.id if preferred, but existing used IDs like 'tarot')
    name: course.title,
    description: course.subTitle || "",
    steps: course.steps.map(step => ({ step: step.stepNumber, label: step.label })),
    cards: course.cards.map(card => {
        let url = card.url;
        let img = card.image?.url || placeholderImg;

        if (card.title.includes("リーダー")) {
            url = "/course#reader";
            img = leader1Img;
        } else if (card.title.includes("コーチ")) {
            url = "/course#coach";
            img = coach1Img;
        } else if (card.title.includes("ティーチャー")) {
            url = "/course#teacher";
             img = teacher1Img;
        }

        return {
            title: card.title,
            img: img,
            url: url
        };
    })
}));
---

<Layout title="Home" wide={true} isHome={true}>
	<!-- Hero Section (Immersive Full Screen) -->
	<section
		class="relative h-screen w-full flex items-center justify-center overflow-hidden"
	>
		<!-- Background Image Slideshow -->
		<div class="absolute inset-0 z-0">
			<div
				class="absolute inset-0 bg-text-dark/30 z-10 pointer-events-none"
			>
			</div>
			<!-- Overlay -->

			<Image
				src={top1Img as any}
				alt="Hero Background 1"
				class="absolute inset-0 w-full h-full object-cover transition-opacity duration-[2000ms] ease-in-out opacity-100 hero-bg"
				data-index="0"
                loading="eager"
                decoding="sync"
			/>
			<Image
				src={top2Img as any}
				alt="Hero Background 2"
				class="absolute inset-0 w-full h-full object-cover transition-opacity duration-[2000ms] ease-in-out opacity-0 hero-bg"
				data-index="1"
                loading="eager"
                decoding="sync"
			/>
			<Image
				src={top3Img as any}
				alt="Hero Background 3"
				class="absolute inset-0 w-full h-full object-cover transition-opacity duration-[2000ms] ease-in-out opacity-0 hero-bg"
				data-index="2"

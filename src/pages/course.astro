---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

import leaderImg from "../assets/images/home/leader_1.webp";
import coachImg from "../assets/images/home/coach_1.webp";
import teacherImg from "../assets/images/home/teacher_1.webp";

// Data Definitions
const courseCategories = [
    {
        id: "voyager",
        title: "ボイジャータロット",
        sub: "Voyager Tarot",
        description: "ボイジャータロットの認定講座です。基礎からプロフェッショナルまで段階的に学べます。",
        courses: [
            {
                id: "reader",
                step: "STEP 1",
                stepColor: "sakura-vivid", // Red
                bgGradient: "bg-sakura-vivid/20",
                image: leaderImg,
                title: "認定リーダー養成講座",
                subtitle: "基礎を学び、自分と他者をリーディングできるようになる",
                description: "ボイジャータロットの基礎と78枚のカードの解説、基本のリーディングを学びます。<br />ボイジャータロットがどんなカードかを理解し、自分で行うセルフリーディングから他者への基礎リーディングが出来るようになります。",
                subCourses: [
                    {
                        title: "STEP 1-1: ベーシック講座",
                        duration: "12時間 (4時間×3回)",
                        description: "カードの基礎知識、直感の磨き方、基本スプレッドを習得し、有料セッションへの第一歩を踏み出します。",
                        contents: [
                            "ボイジャータロットの特徴と作者の紹介",
                            "ボイジャータロットの基礎知識",
                            "カードの使い方",
                            "リーディングの心構え",
                            "全78枚完全解説",
                            "Q＆Aリーディング",
                            "基本の１枚引きリーディング",
                            "私は誰？ゲーム (ゲームを楽しみながらカードを読む力が身に付きます。)",
                            "関係性リーディング (気になる人との関係性がわかるリーディング)",
                            "ヒーローズジャーニー (定番のスプレッド。４枚のカードを順序立てて引くので使いやすく初心者の方にも人気のリーディング)",
                            "選択リーディング (選択に迷った時に！速攻で決断できる簡単リーディング)",
                            "マジックリング (自分の強みや才能を発見し、最大限活用する方法を見つけ可能性を開くスプレッド。)"
                        ],
                        condition: null
                    },
                    {
                        title: "STEP 1-2: アドバンス講座",
                        duration: "12時間 (4時間×3回)",
                        description: "基礎リーディングが出来るようになった、次のステップの講座です。 大型スプレッドでリーディングのスキルが大きく上がります。ここをマスターするとプロの道へ到達します。 すでにカードを覚えている段階なので、更にボイジャーの知識を深め、リーディングが楽しくなってきます。 カードを楽しむ事によって、自然に知識や理解を深められます。",
                        contents: [
                            "家族カードリーディング (家族以外の人間関係にも使えるスプレッド)",
                            "数秘術カードと数秘術基礎 (ボイジャータロットには数秘術の要素が含まれます。より深めるために必要な知識をしっかり学びます。)",
                            "占星術カードと占星術基礎 (占星術の超基礎の知識と対応カードを学びます。)",
                            "スターツリーリーディング (人生の展開を読み解く大型スプレッド。自分の持つ性質、テーマへの可能性、そこからどう成長して実現していくのかの展開を読んでいきます。)",
                            "ネガティブカードリーディング (ボイジャータロットには『ネガティブカード』と呼ばれるチャンスカードがあります。ネガティブカードをマスターするとリーディングのスキルが上がり、お客様を勇気づけ魂の成長を促す事が出来ます。)",
                            "ヒーローズジャーニー応用版 (ベーシック講座で学んだヒーローズジャーニーを更にわかりやすくした応用版です。)",
                            "物語を作るリーディング (直感と想像力を使って自由にストーリーを作って楽しむ右脳系リーディングです。感じたことを言語化する力が身に付きます。)",
                            "選択リーディング (大事な選択や決断に迫られている時に役立つリーディング。)",
                            "ホールセルフマンダラ (新年や誕生日など節目の時期におススメのスプレッド。仕事、恋愛などカテゴリ別のカードや、内面を映し出すカードで今後の全体像を見ていきます。)",
                            "認定課題"
                        ],
                        condition: {
                            title: "認定条件",
                            items: ["20時間のリーディング記録の提出", "認定テスト（モニターセッション30分）"],
                            color: "sakura-vivid",
                            bgColor: "bg-pink-50/50",
                            borderColor: "border-pink-100/50"
                        }
                    }
                ],
                 pricing: [
                    { title: "認定リーダー養成講座 (ベーシック)", duration: "全12時間", price: "¥55,000" },
                    { title: "認定リーダー養成講座 (アドバンス)", duration: "全12時間", price: "¥55,000" }
                ]
            },
            {
                id: "coach",
                step: "STEP 2",
                stepColor: "sunshine", // Yellow
                bgGradient: "bg-sunshine/20",
                image: coachImg,
                title: "認定コーチ養成講座",
                subtitle: "質問力を磨き、行動を促すコーチングスキルを習得",
                description: "占いやカウンセリングの知識を得ても、スムーズなセッションが出来なかったり、自分自身が思うように生きられていなければ活かしていく事は出来ません。単なる占いのツールではなく、行動を促し未来をクリエイトするのがボイジャータロットのパワー。ボイジャーを使った実践的なコーチングスキルを学び、自分自身も取り組むことで、学びと行動の習慣化を両立し、身につけることが出来る講座です。受講しながら自分自身にも変化を起こし、目標達成を叶えていきます。この先のティーチャーとして活躍していきたい方にも重要な講座です。",
                subCourses: [
                    {
                        title: "コーチ認定講座",
                        duration: "12時間 (3時間×4回)",
                        description: "質問力を磨き、クライアントの答えを引き出すコーチング手法を習得します。<br />継続セッションの技術も学び、リピーターに繋がる実力をつけます。",
                        contents: [
                            "ボイジャータロットコーチングとは？",
                            "ボイジャーコーチングの法則",
                            "ボイジャーコーチングの進め方",
                            "ボイジャーコーチングに大切な3つの要素",
                            "アクションマップと４つのスプレッド"
                        ],
                        condition: {
                            title: "認定条件",
                            items: ["3名の方に3回の継続セッションを実施・記録提出", "認定テスト（モニターセッション60分）"],
                            color: "sunshine",
                            bgColor: "bg-yellow-50/50",
                            borderColor: "border-yellow-100/50"
                        }
                    }
                ],
                pricing: [
                    { title: "認定コーチ養成講座", duration: "全12時間", price: "¥88,000" }
                ]
            },
            {
                id: "teacher",
                step: "STEP 3",
                stepColor: "sky", // Blue
                bgGradient: "bg-sky/20",
                image: teacherImg,
                title: "認定ティーチャー養成講座",
                subtitle: "ボイジャータロットを教え、広める存在になる",
                description: "認定ティーチャーとして『リーダー認定講座(ベーシック・アドバンス)』を開催できるようになります。<br />教える立場になることで、カードへの理解が圧倒的に深まり、ビジネスとしての活動の幅も広がります。",
                subCourses: [
                    {
                        title: "ティーチャー認定講座",
                        duration: "要問い合わせ",
                        description: "インストラクション技術、集客、ブランディングなど、指導者・経営者としてのスキルを総合的に学びます。",
                        contents: [
                            "起業のための実践ビジネス講座",
                            "開業までの流れと準備",
                            "集客の方法",
                            "ティーチャーとしての心得とレクチャー 　　　など"
                        ],
                        condition: {
                            title: "認定条件",
                            items: ["50時間の有料セッション実施・記録提出", "講座アシスタント経験・集客実績", "レポート提出"],
                            color: "sky",
                            bgColor: "bg-blue-50/50",
                            borderColor: "border-blue-100/50"
                        }
                    }
                ],
                pricing: [
                    { title: "認定ティーチャー養成講座", duration: "要問い合わせ", price: "¥120,000" }
                ]
            }
        ]
    },
    {
        id: "other",
        title: "その他講座（例）",
        sub: "Other Courses",
        description: "数秘術や占星術など、その他の講座も準備中です。",
        courses: [
             {
                id: "example",
                step: "COMING SOON",
                stepColor: "gray-400",
                bgGradient: "bg-gray-100",
                image: leaderImg,
                title: "数秘術講座（準備中）",
                subtitle: "数字の神秘を学び、自己理解を深める",
                description: "現在準備中です。公開までしばらくお待ちください。",
                subCourses: [],
                pricing: []
            }
        ]
    }
];
---

<Layout title="Course Guide">
    <div class="pt-32 pb-16 space-y-16">
        <!-- Header -->
        <header class="text-center mb-16 relative">
            <h1
                class="text-4xl md:text-7xl font-serif font-black tracking-wider text-text-dark bg-clip-text bg-gradient-to-r from-text-dark to-slate-500 mb-4 drop-shadow-sm"
            >
                Course Guide
            </h1>
            <div class="w-16 h-[2px] bg-magenta mx-auto mt-6 mb-8"></div>
        </header>

        <!-- Main Content Layout -->
        <div class="grid md:grid-cols-12 gap-0 md:gap-8 items-start relative">
            
            <!-- Sidebar Navigation (Sticky on Desktop) -->
            <aside class="md:col-span-3 md:sticky md:top-32 z-20 w-full overflow-hidden">
                <nav class="bg-white/50 backdrop-blur-md rounded-[2rem] p-4 border border-white shadow-glass w-full">
                    <ul class="flex md:flex-col gap-2 overflow-x-auto md:overflow-visible pb-2 md:pb-0 touch-action-pan-x snap-x no-scrollbar w-full">
                        {courseCategories.map((cat, index) => (
                            <li class="snap-start shrink-0">
                                <button
                                    class:list={[
                                        "category-tab w-full text-center justify-center px-4 py-3 md:px-6 md:py-4 rounded-xl transition-all duration-300 font-bold tracking-wide flex items-center gap-3 group border border-transparent whitespace-nowrap",
                                        index === 0 
                                            ? "bg-text-dark text-white shadow-lg shadow-gray-200" 
                                            : "hover:bg-white hover:shadow-md text-gray-500 hover:text-text-dark"
                                    ]}
                                    data-target={cat.id}
                                >
                                    <span class:list={[
                                        "w-2 h-2 rounded-full transition-colors duration-300",
                                        index === 0 ? "bg-sakura-vivid" : "bg-gray-300 group-hover:bg-text-dark"
                                    ]}></span>
                                    <div class="flex flex-col items-center">
                                        <span class="text-sm md:text-base">{cat.title}</span>
                                        <span class="text-[10px] uppercase tracking-widest opacity-60 hidden md:block">{cat.sub}</span>
                                    </div>
                                </button>
                            </li>
                        ))}
                    </ul>
                </nav>
            </aside>

            <!-- Course Content Area -->
            <div class="md:col-span-9 min-h-[500px]">
                {courseCategories.map((cat, index) => (
                    <div 
                        id={cat.id} 
                        class:list={["category-content transition-all duration-700 ease-in-out p-4 md:p-12 rounded-[2rem] md:rounded-[2.5rem] relative overflow-hidden", 
                            index !== 0 ? "hidden opacity-0 translate-y-4" : "block opacity-100 translate-y-0",
                            cat.id === 'voyager' ? 'bg-magenta-pale/30' : 
                            cat.id === 'coach' ? 'bg-yellow-50/40' : 
                            'bg-blue-50/40'
                        ]}
                    >
                        {/* Decorative background blobs */}
                        <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
                            <div class:list={[
                                "absolute -top-24 -left-24 w-96 h-96 blur-[100px] opacity-20 rounded-full",
                                cat.id === 'voyager' ? 'bg-magenta' : cat.id === 'coach' ? 'bg-sunshine' : 'bg-sky'
                            ]}></div>
                            <div class:list={[
                                "absolute bottom-0 -right-24 w-80 h-80 blur-[80px] opacity-15 rounded-full",
                                cat.id === 'voyager' ? 'bg-sakura-vivid' : cat.id === 'coach' ? 'bg-yellow-200' : 'bg-blue-200'
                            ]}></div>
                        </div>
                        
                        <!-- Category Header -->
                        <div class:list={[
                            "mb-12 pl-6 border-l-4 rounded-r-lg py-2",
                            cat.id === 'voyager' ? 'border-magenta bg-magenta/5' : 
                            cat.id === 'coach' ? 'border-sunshine bg-sunshine/5' : 
                            'border-sky bg-sky/5'
                        ]}>
                            <h2 class="text-3xl font-bold text-text-dark mb-2">{cat.title}</h2>
                            <p class="text-gray-500">{cat.description}</p>
                        </div>

                        <div class="space-y-16 md:space-y-24">
                            {cat.courses.map((course) => (
                                <div
                                    id={course.id}
                                    class:list={[
                                        "bg-white/95 backdrop-blur-md rounded-[2rem] md:rounded-[2.5rem] border border-white shadow-xl relative overflow-hidden group hover:shadow-2xl transition-all duration-500 scroll-mt-40 mb-10 md:mb-16",
                                        cat.id === 'voyager' ? 'shadow-magenta/10 hover:shadow-magenta/20' : 
                                        cat.id === 'coach' ? 'shadow-sunshine/10 hover:shadow-sunshine/20' : 
                                        'shadow-sky/10 hover:shadow-sky/20'
                                    ]}
                                >
                                    <div class="flex flex-col">
                                        <!-- Image Block (Top, fixed aspect ratio) -->
                                        <div class="w-full h-48 md:h-64 relative overflow-hidden">
                                            <Image
                                                src={course.image as any}
                                                alt={course.title}
                                                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                            />
                                            <div class="absolute inset-0 bg-gradient-to-t from-white via-transparent to-transparent"></div>
                                            
                                        </div>

                                        <!-- Content Block -->
                                        <div class="p-6 md:p-12">
                                            <div class="mb-10">
                                                <div>
                                                    <span class:list={["inline-block text-[10px] font-black uppercase tracking-widest mb-3 px-3 py-1 rounded-full text-white", `bg-${course.stepColor}`]}>
                                                        {course.step}
                                                    </span>
                                                    <h4 class="text-2xl md:text-3xl font-bold text-text-dark mb-2">
                                                        {course.title}
                                                    </h4>
                                                    <p class="text-gray-500 leading-relaxed max-w-xl">{course.subtitle}</p>
                                                </div>
                                                <div class:list={["w-12 h-1 mb-8 rounded-full opacity-20", `bg-${course.stepColor}`]}></div>
                                                <p class="text-gray-600 leading-relaxed">
                                                    <Fragment set:html={course.description} />
                                                </p>
                                            </div>
        
                                            <!-- Sub Courses -->
                                            <div class="space-y-6">
                                                {course.subCourses.map((sub) => (
                                                    <div class:list={[
                                                        "bg-white p-5 md:p-8 rounded-2xl md:rounded-3xl border border-gray-100/50 shadow-xl transition-all duration-300 hover:shadow-2xl",
                                                        cat.id === 'voyager' ? 'shadow-magenta/5 hover:shadow-magenta/10' : 
                                                        cat.id === 'coach' ? 'shadow-sunshine/5 hover:shadow-sunshine/10' : 
                                                        'shadow-sky/5 hover:shadow-sky/10'
                                                    ]}>
                                                        <div class="flex flex-col md:flex-row justify-between items-baseline mb-4 gap-2">
                                                            <h5 class="font-bold text-xl text-text-dark">
                                                                {sub.title}
                                                            </h5>
                                                            <span class="text-[10px] font-black text-gray-400 bg-gray-50 px-3 py-1.5 rounded-full uppercase tracking-tighter">
                                                                期間: {sub.duration}
                                                            </span>
                                                        </div>
                                                        <p class="text-gray-500 text-sm leading-relaxed mb-6">
                                                            <Fragment set:html={sub.description} />
                                                        </p>

                                                        {sub.contents && (
                                                            <div class:list={[
                                                                "mb-6 md:mb-8 p-5 md:p-8 rounded-2xl md:rounded-3xl border border-white/50 shadow-inner",
                                                                cat.id === 'voyager' ? 'bg-magenta-pale/30' : 
                                                                cat.id === 'coach' ? 'bg-yellow-50/50' : 
                                                                'bg-blue-50/50'
                                                            ]}>
                                                                <h6 class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-5 flex items-center gap-3">
                                                                    <span class:list={["w-1.5 h-4 rounded-full", `bg-${course.stepColor}`]}></span>
                                                                    講座内容
                                                                </h6>
                                                                <ul class="grid grid-cols-1 gap-4">
                                                                    {sub.contents.map((item: string) => (
                                                                        <li class="flex items-start gap-3 text-sm text-gray-700 leading-relaxed font-medium">
                                                                            <div class:list={["mt-0.5 p-0.5 rounded-full bg-white shadow-sm ring-1", `ring-${course.stepColor}/20`]}>
                                                                                <svg xmlns="http://www.w3.org/2000/svg" class:list={["h-3.5 w-3.5", `text-${course.stepColor}`]} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                                                                                </svg>
                                                                            </div>
                                                                            <span>{item}</span>
                                                                        </li>
                                                                    ))}
                                                                </ul>
                                                            </div>
                                                        )}
        
                                                        {sub.condition && (
                                                            <div class:list={["p-5 rounded-xl border border-dashed", sub.condition.bgColor, sub.condition.borderColor]}>
                                                                <h6 class:list={["font-bold text-[10px] uppercase tracking-widest mb-3", `text-${sub.condition.color}`]}>
                                                                    {sub.condition.title}
                                                                </h6>
                                                                <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-2 text-xs text-gray-500 font-medium">
                                                                    {sub.condition.items.map(item => (
                                                                        <li class="flex items-start gap-2">
                                                                            <span class="mt-1.5 w-1 h-1 rounded-full bg-current opacity-30 shrink-0"></span>
                                                                            {item}
                                                                        </li>
                                                                    ))}
                                                                </ul>
                                                            </div>
                                                        )}
                                                    </div>
                                                ))}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>

                        <!-- Pricing Table (Per Category) -->
                         {cat.courses.some(c => c.pricing.length > 0) && (
                            <section class="mt-16 md:mt-24 bg-white/80 backdrop-blur-sm p-6 md:p-12 rounded-[2rem] md:rounded-[3rem] border border-white shadow-sm">
                                <h3 class="text-xl md:text-3xl font-bold text-center mb-6 md:mb-10 text-text-dark">
                                    {cat.title} 価格一覧
                                </h3>
                                <div class="overflow-x-auto">
                                    <table class="w-full text-left border-collapse">
                                        <thead class:list={[
                                            "text-xs uppercase tracking-widest border-b",
                                            cat.id === 'voyager' ? 'bg-magenta/10 border-magenta/20 text-magenta' : 
                                            cat.id === 'coach' ? 'bg-sunshine/10 border-sunshine/20 text-sunshine' : 
                                            'bg-sky/10 border-sky/20 text-sky'
                                        ]}>
                                            <tr>
                                                <th class="p-4 md:p-6 font-black whitespace-nowrap text-[10px] md:text-xs">講座名</th>
                                                <th class="p-4 md:p-6 font-black whitespace-nowrap text-[10px] md:text-xs">期間</th>
                                                <th class="p-4 md:p-6 font-black text-right whitespace-nowrap text-[10px] md:text-xs">料金（税込）</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-gray-50">
                                            {cat.courses.flatMap(c => c.pricing).map((price) => (
                                                <tr class:list={[
                                                    "transition-colors",
                                                    cat.id === 'voyager' ? 'hover:bg-magenta/5' : 
                                                    cat.id === 'coach' ? 'hover:bg-sunshine/5' : 
                                                    'hover:bg-sky/5'
                                                ]}>
                                                    <td class="p-4 md:p-6 font-bold text-text-dark text-xs md:text-base min-w-[120px]">{price.title}</td>
                                                    <td class="p-4 md:p-6 text-gray-600 text-[10px] md:text-sm font-medium whitespace-nowrap">{price.duration}</td>
                                                    <td class="p-4 md:p-6 text-right font-bold text-text-dark text-xs md:text-base whitespace-nowrap">{price.price}</td>
                                                </tr>
                                            ))}
                                        </tbody>
                                    </table>
                                </div>
                            </section>
                         )}
                    </div>
                ))}
            </div>
        </div>

        <!-- Application CTA -->
        <div class="mt-16 text-center">
            <a
                href="https://tol-app.jp/s/aoki-sakuracom"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 bg-gradient-to-r from-[#ff80ab] to-[#ffb300] text-white px-12 py-5 rounded-full font-bold hover:scale-105 transition-all shadow-lg shadow-pink-200 tracking-wider group"
            >
                <div>
                     <span class="block text-sm opacity-90 font-normal mb-0.5">外部予約サイトへ</span>
                    講座へのお申し込み
                </div>
                 <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
            </a>
            <p class="text-gray-400 text-sm mt-4">
                ※ご質問がある場合は <a href="/contact" class="text-sakura-vivid hover:underline decoration-sakura-vivid/50">お問い合わせフォーム</a> へ
            </p>
        </div>
    </div>
</Layout>

<script>
    // Tab Switching Logic
    const tabs = document.querySelectorAll('.category-tab');
    const contents = document.querySelectorAll('.category-content');
    
    // Manual tab switching logic for direct click handling
    function switchTab(targetId: string) {
         // 1. Reset Tabs
         tabs.forEach(t => {
                t.classList.remove('bg-text-dark', 'text-white', 'shadow-lg', 'shadow-gray-200');
                t.classList.add('hover:bg-white', 'hover:shadow-md', 'text-gray-500', 'hover:text-text-dark');
                
                const marker = t.querySelector('span');
                if(marker) {
                    marker.classList.remove('bg-sakura-vivid');
                    marker.classList.add('bg-gray-300');
                }
            });

            // 2. Find and Activate Tab
            const activeTab = document.querySelector(`.category-tab[data-target="${targetId}"]`);
            if (activeTab) {
                activeTab.classList.remove('hover:bg-white', 'hover:shadow-md', 'text-gray-500', 'hover:text-text-dark');
                activeTab.classList.add('bg-text-dark', 'text-white', 'shadow-lg', 'shadow-gray-200');
                
                const activeMarker = activeTab.querySelector('span');
                if(activeMarker) {
                    activeMarker.classList.remove('bg-gray-300');
                    activeMarker.classList.add('bg-sakura-vivid');
                }
            }

            // 3. Switch Content
            contents.forEach(content => {
                content.classList.add('hidden', 'opacity-0', 'translate-y-4');
                content.classList.remove('block', 'opacity-100', 'translate-y-0');
            });
            
            const targetContent = document.getElementById(targetId);
            if (targetContent) {
                 targetContent.classList.remove('hidden');
                 // Small delay to allow display:block to apply before animating opacity
                 setTimeout(() => {
                    targetContent.classList.remove('opacity-0', 'translate-y-4');
                    targetContent.classList.add('opacity-100', 'translate-y-0');
                 }, 10);
            }
    }

    tabs.forEach(tab => {
        tab.addEventListener('click', (e) => {
             const targetId = (e.currentTarget as HTMLElement).dataset.target;
             if (targetId) switchTab(targetId);
        });
    });

    // Handle hash links for direct deep linking
    window.addEventListener('load', () => {
        if(window.location.hash) {
            const hash = window.location.hash.replace('#', '');
            // Check if hash matches a category ID
            if(document.getElementById(hash) && document.querySelector(`.category-tab[data-target="${hash}"]`)) {
                 switchTab(hash);
            }
        }
    });

</script>


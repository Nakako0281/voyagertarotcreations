---

<Layout title="Course Guide">
    <div class="pt-32 pb-16 space-y-16">
        <!-- Header -->
        <header class="text-center mb-16 relative">
            <h1
                class="text-4xl md:text-7xl font-serif font-black tracking-wider text-text-dark bg-clip-text bg-gradient-to-r from-text-dark to-slate-500 mb-4 drop-shadow-sm"
            >
                Course Guide
            </h1>
            <div class="w-16 h-[2px] bg-[#8b5cf6] mx-auto mt-6 mb-8"></div>
        </header>

        <!-- Main Content Layout -->
        <div class="grid md:grid-cols-12 gap-0 md:gap-8 items-start relative">
            
            <!-- Sidebar Navigation (Sticky on Desktop) -->
            <aside class="md:col-span-3 md:sticky md:top-32 z-20 w-full">
                <nav class="bg-white/70 md:bg-white/50 backdrop-blur-md rounded-[2rem] p-2 md:p-4 border border-white shadow-glass w-full">
                    <ul class="grid grid-cols-2 md:flex md:flex-col gap-2 w-full">
                        {courseCategories.map((cat, index) => (
                            <li class="w-full">
                                <button
                                    class:list={[
                                        "category-tab w-full h-full text-center justify-center px-2 py-3 md:px-6 md:py-4 rounded-xl transition-all duration-300 font-bold tracking-wide flex flex-col items-center gap-1 group border",
                                        index === 0 
                                            ? "bg-[#8b5cf6] border-transparent text-white shadow-lg shadow-gray-200" 
                                            : "bg-white border-[#8b5cf6]/30 text-gray-600 hover:bg-[#8b5cf6]/5 hover:shadow-md hover:text-text-dark"
                                    ]}
                                    data-target={cat.id}
                                >
                                    <div class="flex flex-col items-center">
                                        <span class="text-xs md:text-base whitespace-nowrap leading-tight">{cat.tabTitle || cat.title}</span>
                                    </div>
                                </button>
                            </li>
                        ))}
                    </ul>
                </nav>
            </aside>

            <!-- Course Content Area -->
            <div class="md:col-span-9 min-h-[500px]">
                {courseCategories.map((cat, index) => (
                    <div 
                        id={cat.id} 

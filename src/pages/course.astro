<script>
    // Tab Switching Logic
    const tabs = document.querySelectorAll('.category-tab');
    const contents = document.querySelectorAll('.category-content');
    
    // Manual tab switching logic for direct click handling
    function switchTab(targetId: string) {
         // 1. Reset Tabs
         tabs.forEach(t => {
                t.classList.remove('bg-[#8b5cf6]', 'border-transparent', 'text-white', 'shadow-lg', 'shadow-gray-200');
                t.classList.add('bg-white', 'border-[#8b5cf6]/30', 'text-gray-600', 'hover:bg-[#8b5cf6]/5', 'hover:shadow-md', 'hover:text-text-dark');
            });

            // 2. Find and Activate Tab
            const activeTab = document.querySelector(`.category-tab[data-target="${targetId}"]`);
            if (activeTab) {
                activeTab.classList.remove('bg-white', 'border-[#8b5cf6]/30', 'text-gray-600', 'hover:bg-[#8b5cf6]/5', 'hover:shadow-md', 'hover:text-text-dark');
                activeTab.classList.add('bg-[#8b5cf6]', 'border-transparent', 'text-white', 'shadow-lg', 'shadow-gray-200');
            }

            // 3. Switch Content
            contents.forEach(content => {
                content.classList.add('hidden', 'opacity-0', 'translate-y-4');
                content.classList.remove('block', 'opacity-100', 'translate-y-0');
            });
            
            const targetContent = document.getElementById(targetId);
            if (targetContent) {
                 targetContent.classList.remove('hidden');
                 // Small delay to allow display:block to apply before animating opacity
                 setTimeout(() => {
                    targetContent.classList.remove('opacity-0', 'translate-y-4');
                    targetContent.classList.add('opacity-100', 'translate-y-0');
                 }, 10);
            }
    }

    tabs.forEach(tab => {
        tab.addEventListener('click', (e) => {
             const targetId = (e.currentTarget as HTMLElement).dataset.target;
             if (targetId) switchTab(targetId);
        });
    });

    // Handle hash links for direct deep linking
    window.addEventListener('load', () => {
        if(window.location.hash) {
            const hash = window.location.hash.replace('#', '');
            
            // 1. カテゴリーID（親タブ）に直接一致する場合
            if (document.querySelector(`.category-tab[data-target="${hash}"]`)) {
                 switchTab(hash);
                 return;
            }
            
            // 2. 講座ID（タブの中身）に一致する場合
            const targetElement = document.getElementById(hash);
            if (targetElement) {
                const parentCategory = targetElement.closest('.category-content');
                if (parentCategory) {
                    const categoryId = parentCategory.id;
                    switchTab(categoryId);
                    setTimeout(() => {
                        targetElement.scrollIntoView({ behavior: 'smooth' });
                    }, 100);
                }
            }
        }
    });

</script>


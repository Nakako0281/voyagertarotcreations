---
import Layout from "../../layouts/Layout.astro";
import { getNews, getNewsDetail } from "../../library/microcms";
import { format } from "date-fns";

export async function getStaticPaths() {
    try {
        const response = await getNews();
        if (!response || !response.contents) return [];
        return response.contents.map((content: any) => ({
            params: {
                id: content.id,
            },
        }));
    } catch (error) {
        console.error("Error generating static paths for news:", error);
        return [];
    }
}

const { id } = Astro.params;
const news = await getNewsDetail(id as string);

function formatDate(dateString: string) {
    return format(new Date(dateString), "yyyy.MM.dd");
}
---

<Layout 
    title={news?.title || "お知らせ"} 
    description={news ? `${news.title}。ボイジャータロット クリエイションズの最新情報をお届けします。` : "ボイジャータロット クリエイションズのお知らせ詳細ページです。"}
>
    <div class="max-w-4xl mx-auto">
        {news ? (
            <article
                class="bg-white/80 backdrop-blur-md p-8 md:p-12 rounded-[3rem] shadow-glass border border-white relative overflow-hidden"
            >
                <!-- Header -->
                <header class="mb-12 pb-8 border-b border-gray-100 relative z-10">
                    <div class="flex items-center gap-4 mb-6">
                        <time
                            class="text-gray-600 font-bold tracking-wider"
                            datetime={news.publishedAt}
                        >
                            {formatDate(news.publishedAt)}
                        </time>
                        {
                            (news.category && news.category.length > 0) ? (
                                news.category.map((cat: any) => (
                                    <span class="text-sm text-sakura-vivid font-bold border border-sakura-vivid/30 bg-sakura-light/10 px-3 py-1 rounded-full backdrop-blur-sm">
                                        {cat.name}
                                    </span>
                                ))
                            ) : (
                                <span class="text-sm text-sakura-vivid font-bold border border-sakura-vivid/30 bg-sakura-light/10 px-3 py-1 rounded-full backdrop-blur-sm">
                                    お知らせ
                                </span>
                            )
                        }
                    </div>
                    <h1
                        class="text-3xl md:text-5xl font-bold text-text-main leading-relaxed"
                    >
                        {news.title}
                    </h1>
                </header>

                {
                    news.eyecatch && (
                        <div class="mb-12 rounded-2xl overflow-hidden shadow-lg shadow-gray-200/50 relative z-10 max-w-2xl mx-auto">
                            <div class="aspect-video w-full bg-white/50 backdrop-blur-sm flex items-center justify-center">
                                <img
                                    src={`${news.eyecatch.url}?w=1200&q=75&fm=webp`}
                                    alt={news.title}
                                    class="max-w-full max-h-full object-contain"
                                />
                            </div>
                        </div>
                    )
                }

                <!-- Content -->
                <div
                    class="news-content prose prose-lg prose-p:text-gray-600 max-w-none relative z-10"
                    set:html={news.content}
                />

                <style is:global>
                    /* お知らせ本文専用のスタイル（他ページには影響しません） */
                    .news-content {
                        letter-spacing: 0.08em !important;
                        line-height: 1.8 !important;
                    }
                    .news-content p {
                        margin-bottom: 2rem !important;
                        color: #4b5563 !important;
                    }
                    /* リスト表現の強制（Tailwindのリセットを上書き） */
                    .news-content ul {
                        list-style-type: disc !important;
                        list-style-position: inside !important; /* 内側に配置して確実に見せる */
                        padding-left: 0.5rem !important;
                        margin-bottom: 2rem !important;
                        display: block !important;
                    }
                    .news-content ol {
                        list-style-type: decimal !important;
                        list-style-position: inside !important;
                        padding-left: 0.5rem !important;
                        margin-bottom: 2rem !important;
                        display: block !important;
                    }
                    .news-content li {
                        margin-bottom: 0.75rem !important;
                        display: list-item !important; /* リストとして表示を強制 */
                    }
                    /* 見出しの調整 */
                    .news-content h1, 
                    .news-content h2, 
                    .news-content h3 {
                        margin-top: 3rem !important;
                        margin-bottom: 1.5rem !important;
                        letter-spacing: 0.15em !important;
                        font-weight: bold !important;
                        color: #1f2937 !important;
                    }
                    /* リンク */
                    .news-content a {
                        color: #f472b6 !important; /* sakura-vivid */
                        text-decoration: underline !important;
                    }
                </style>

                <!-- Navigation -->
                <div
                    class="mt-16 pt-12 border-t border-gray-100 text-center relative z-10"
                >
                    <a
                        href="/news"
                        class="inline-flex items-center px-8 py-3 rounded-full border border-gray-300 text-gray-700 font-bold tracking-widest hover:border-sakura-vivid hover:text-sakura-vivid transition-all group duration-300 bg-white/50 backdrop-blur-sm"
                    >
                        <span
                            class="mr-2 group-hover:-translate-x-1 transition-transform"
                            >&larr;</span
                        >
                        BACK TO NEWS
                    </a>
                </div>

                <!-- Background Decoration -->
                <div
                    class="absolute top-0 right-0 w-96 h-96 bg-gradient-to-b from-sakura-light/20 to-transparent rounded-bl-full z-0 blur-3xl opacity-50 pointer-events-none"
                >
                </div>
                <div
                    class="absolute bottom-0 left-0 w-64 h-64 bg-gradient-to-t from-sky/10 to-transparent rounded-tr-full z-0 blur-3xl opacity-50 pointer-events-none"
                >
                </div>
            </article>
        ) : (
            <div class="text-center py-24 bg-white/40 backdrop-blur-lg rounded-[3rem] border border-dashed border-sakura-vivid/20 max-w-2xl mx-auto shadow-sm">
                <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-8 shadow-sm text-sakura-vivid">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                </div>
                <h2 class="text-text-main font-bold text-2xl mb-4">お知らせが見つかりませんでした</h2>
                <p class="text-text-main/60 mb-10 leading-relaxed px-6">
                    お探しの記事は削除されたか、URLが変更された可能性があります。<br/>
                    一覧に戻って他のお知らをご確認ください。
                </p>
                <a
                    href="/news"
                    class="inline-flex items-center px-8 py-3 rounded-full border border-sakura-vivid text-sakura-vivid font-bold hover:bg-sakura-vivid hover:text-white transition-all duration-300"
                >
                    &larr; お知らせ一覧へ戻る
                </a>
            </div>
        )}
    </div>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import { getNews } from "../../library/microcms";

const response = await getNews();
const { contents: newsList } = response;

import { format } from "date-fns";

function formatDate(dateString: string) {
    return format(new Date(dateString), "yyyy.MM.dd");
}
---

<Layout title="News">
    <div class="space-y-16">
        <!-- Header -->
        <header class="text-center mb-16 relative">
            <h1
                class="text-5xl md:text-7xl font-serif font-black tracking-wider text-text-dark bg-clip-text bg-gradient-to-r from-text-dark to-slate-500 mb-4 drop-shadow-sm"
            >
                News
            </h1>
            <div class="w-16 h-[2px] bg-magenta mx-auto mt-6 mb-8"></div>
        </header>

        <div class="grid gap-8">
            {
                newsList.length > 0 ? (
                    newsList.map((news) => (
                        <a
                            href={`/news/${news.id}`}
                            class="block bg-white/80 backdrop-blur-md p-6 md:p-8 rounded-[2rem] border border-white shadow-glass hover:shadow-crystal hover:-translate-y-1 transition-all duration-500 group relative overflow-hidden"
                        >
                            <!-- Background Decoration -->
                            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-sakura-light/20 to-transparent rounded-bl-full z-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                            <div class="flex flex-col md:flex-row gap-8 relative z-10">
                                <div class="md:w-64 h-48 rounded-2xl overflow-hidden shrink-0 shadow-sm relative">
                                    {news.eyecatch ? (
                                        <img
                                            src={`${news.eyecatch.url}?w=800&q=75&fm=webp`}
                                            alt={news.title}
                                            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                        />
                                    ) : (
                                        <div class="w-full h-full flex items-center justify-center bg-gray-50 text-gray-300">
                                            <span class="text-xl tracking-widest font-serif opacity-50">Voyager</span>
                                        </div>
                                    )}
                                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-500"></div>
                                </div>
                                <div class="flex-1 flex flex-col justify-between h-full md:min-h-[12rem] py-2">
                                    <div>
                                        <div class="flex items-center gap-4 mb-4">
                                            <time class="text-sm text-gray-600 font-bold tracking-wider">
                                                {formatDate(news.publishedAt)}
                                            </time>
                                            {news.category && news.category.length > 0 ? (
                                                news.category.map((cat) => (
                                                    <span class="text-sm text-sakura-vivid font-bold border border-sakura-vivid/30 bg-sakura-light/10 px-3 py-1 rounded-full backdrop-blur-sm">
                                                        {cat.name}
                                                    </span>
                                                ))
                                            ) : (
                                                <span class="text-sm text-sakura-vivid font-bold border border-sakura-vivid/30 bg-sakura-light/10 px-3 py-1 rounded-full backdrop-blur-sm">
                                                    お知らせ
                                                </span>
                                            )}
                                        </div>
                                        <h2 class="text-xl md:text-2xl font-bold text-text-main group-hover:text-sakura-vivid transition-colors leading-relaxed mb-4 line-clamp-2">
                                            {news.title}
                                        </h2>
                                    </div>
                                    <div class="flex justify-end">
                                        <span class="text-sm font-bold text-gray-600 group-hover:text-sakura-vivid transition-colors flex items-center gap-2">
                                            Read More <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    ))
                ) : (
                    <div class="text-center py-24 bg-white/40 backdrop-blur-lg rounded-[3rem] border border-dashed border-sakura-vivid/20 shadow-sm">
                        <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-8 shadow-sm text-sakura-vivid">
                             <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 11V7l-4 4 4 4v-4z" />
                            </svg>
                        </div>
                        <h2 class="text-text-main font-bold text-2xl mb-4">現在、お知らせはありません</h2>
                        <p class="text-text-main/60 max-w-md mx-auto leading-relaxed">
                            新しいお知らせが投稿されるまで、今しばらくお待ちください。<br/>
                            トップページへ戻って他のコンテンツをお楽しみください。
                        </p>
                        <a href="/" class="inline-block mt-10 text-sakura-vivid font-bold hover:underline">
                            &larr; ホームへ戻る
                        </a>
                    </div>
                )
            }
        </div>
    </div>
</Layout>



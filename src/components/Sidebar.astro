---
import { Image } from "astro:assets";
import aokiSakuraImg from "../assets/images/AokiSakura_1.webp";
---

<div
    class="flex flex-col gap-6 h-full overflow-y-auto bg-white/50 backdrop-blur-sm p-4 rounded-3xl scrollbar-hide"
>
    <!-- Hide scrollbar locally -->
    <style>
        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }
    </style>
    <div class="text-center">
        <!-- Profile Image Placeholder -->
        <div
            class="w-32 h-32 bg-gray-200 rounded-full mx-auto mb-4 overflow-hidden relative group shadow-crystal border-4 border-white"
        >
            <Image
                src={aokiSakuraImg as any}
                alt="Sakura Aoki"
                class="w-full h-full object-cover"
            />
            <div
                class="absolute inset-0 bg-black/10 flex items-center justify-center text-white text-sm opacity-0 group-hover:opacity-100 transition-opacity"
            >
                Profile
            </div>
        </div>
        <h2
            class="text-xl font-mincho font-bold tracking-widest text-text-dark drop-shadow-sm"
        >
            Aoki Sakura
        </h2>
        <p class="text-sm text-sakura-vivid font-bold tracking-wider">
            青木 咲羅
        </p>
        <p class="text-sm mt-3 leading-relaxed text-gray-600">
            Voyager Tarot Creations主宰。<br />
            ボイジャータロット国際認定ティーチャー。
        </p>
    </div>

    <!-- Navigation removed as per request (redundant with header) -->

    <div class="mt-auto pb-8">
        <a
            href="/contact"
            class="flex items-center justify-center w-full py-4 bg-sky text-white font-bold rounded-full shadow-lg shadow-pink-200 hover:scale-105 transition-all active:scale-95 tracking-wide"
        >
            <span>お問い合わせ</span>
        </a>
        <a
            href="/profile"
            class="block text-center text-sm md:text-base text-gray-600 mt-4 hover:text-sakura-vivid transition-colors font-bold tracking-wider"
        >
            Personal Website &rarr;
        </a>
    </div>
</div>
